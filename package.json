{
  "name": "lan-control-hub",
  "version": "0.1.0",
  "description": "Windows/macOS LAN device control hub for chat, files, commands, terminals, and screen view.",
  "main": "dist/main/index.js",
  "bin": {
    "lch": "scripts/lch.js"
  },
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite --host 0.0.0.0\" \"wait-on http://localhost:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron dist/main/index.js\"",
    "dev:renderer": "vite --host 0.0.0.0",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "electron dist/main/index.js",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:mac": "npm run build && electron-builder --mac zip --x64 --arm64"
  },
  "build": {
    "appId": "local.lan-control-hub.app",
    "productName": "Lan Control Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.*",
      "package.json",
      "scripts/lch.js",
      "scripts/lch.cmd"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Lan-Control-Hub-${version}-win-x64-portable.exe",
      "unpackDirName": false
    },
    "nsis": {
      "artifactName": "Lan-Control-Hub-${version}-win-x64-setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lan Control Hub"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "zip"
      ],
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@vitejs/plugin-react": "^4.2.1",
    "cross-env": "^7.0.3",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "electron": "22.3.27",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  }
}
