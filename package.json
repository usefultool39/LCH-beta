{
  "name": "lan-control-hub",
  "version": "0.20.0",
  "description": "Windows/macOS LAN device control hub for chat, files, commands, terminals, and screen view.",
  "author": "usefultool39",
  "main": "dist/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/usefultool39/LCH-beta.git"
  },
  "bin": {
    "lch": "scripts/lch.js"
  },
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite --host 0.0.0.0\" \"wait-on http://localhost:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron dist/main/index.js\"",
    "dev:renderer": "vite --host 0.0.0.0",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "check": "npm run typecheck && npm run build && node --test \"tests/**/*.test.js\" && npm run release:validate",
    "test": "npm run build:main && node --test \"tests/**/*.test.js\"",
    "audit:prod": "node scripts/audit-prod.js",
    "public:scan": "node scripts/secret-scan.js",
    "release:validate": "node scripts/release-info.js validate",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "electron dist/main/index.js",
    "package:win": "npm run build && electron-builder --win --x64 --publish never",
    "package:mac": "npm run build && electron-builder --mac zip --publish never",
    "package:mac:x64": "npm run build && electron-builder --mac zip --x64 --publish never",
    "package:mac:arm64": "npm run build && electron-builder --mac zip --arm64 --publish never"
  },
  "build": {
    "appId": "local.lan-control-hub.app",
    "productName": "Lan Control Hub",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "mobile/**/*",
      "build/icon.*",
      "package.json",
      "scripts/lch.js",
      "scripts/lch.cmd"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**/*",
      "scripts/lch.js",
      "scripts/lch.cmd"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Lan-Control-Hub-${version}-win-x64-portable.exe",
      "unpackDirName": false
    },
    "nsis": {
      "artifactName": "Lan-Control-Hub-${version}-win-x64-setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lan Control Hub"
    },
    "mac": {
      "icon": "build/icon.png",
      "identity": null,
      "artifactName": "Lan-Control-Hub-${version}-mac-${arch}.${ext}",
      "target": [
        "zip"
      ],
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cross-env": "^7.0.3",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.3.3",
    "vite": "^8.0.16",
    "wait-on": "^7.2.0"
  },
  "optionalDependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1"
  }
}
