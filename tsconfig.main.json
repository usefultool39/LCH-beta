{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "isolatedModules": false,
    "noEmit": false,
    "jsx": "react-jsx"
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/shared/**/*"]
}
